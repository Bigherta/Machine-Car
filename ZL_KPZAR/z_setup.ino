/****************************************************************************
  @功能  : 存放初始化相关的函数
****************************************************************************/

/***********************************************
  函数名称: setup_uart()
  功能介绍: 初始化串口
 ***********************************************/
void setup_uart(void) {
  uart_init(115200);
  delay(200);
}

/***********************************************
  函数名称: setup_ps2()
  功能介绍: 初始化 PS2 手柄
 ***********************************************/
void setup_ps2(void) {
  delay(50);
  ps2_mode = ps2.config_gamepad(PS2_CLK, PS2_CMD, PS2_ATT, PS2_DAT);
  delay(50);
  ps2.read_gamepad();
}