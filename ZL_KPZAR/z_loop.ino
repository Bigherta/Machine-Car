/****************************************************************************
  @功能  : 存放永久循环执行的函数
****************************************************************************/

/***********************************************
  函数名称: loop_ps2()
  功能介绍: 周期读取手柄状态
 ***********************************************/
void loop_ps2(void) {
  static u32 systick_ms_bak = 0;

  if (millis() - systick_ms_bak >= 20) {
    systick_ms_bak = millis();
    ps2.read_gamepad();
  }
}
